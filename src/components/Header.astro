---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/articles', label: 'Articles' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="bg-surface-dark text-white">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold font-heading text-accent">
      Turf Tech HQ
    </a>
    <ul class="hidden md:flex gap-6 items-center">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="hover:text-accent transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/get-a-quote" class="bg-accent text-white font-semibold px-4 py-2 rounded-lg hover:opacity-90 transition-opacity duration-200 text-sm">
          Free Estimate
        </a>
      </li>
    </ul>
    <button
      id="mobile-menu-btn"
      class="md:hidden text-white"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
  <ul id="mobile-menu" class="hidden md:hidden px-4 pb-4 space-y-2">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class="block py-1 hover:text-accent transition-colors duration-200"
        >
          {link.label}
        </a>
      </li>
    ))}
    <li>
      <a href="/get-a-quote" class="block py-1 text-accent font-semibold hover:opacity-90 transition-opacity duration-200">
        Free Estimate
      </a>
    </li>
  </ul>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
