---
import EmailSignup from './EmailSignup.astro';
const year = new Date().getFullYear();
---

<footer class="bg-surface-dark text-white py-8 mt-12">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-4 gap-8">
      <div>
        <h3 class="text-accent font-bold text-lg mb-2">Turf Tech HQ</h3>
        <p class="text-sm text-gray-400">
          Expert landscaping tips, lawn care guides, and garden solutions for homeowners and professionals.
        </p>
      </div>
      <div>
        <h4 class="font-semibold mb-2">Quick Links</h4>
        <ul class="space-y-1 text-sm text-gray-400">
          <li><a href="/articles" class="hover:text-accent">Articles</a></li>
          <li><a href="/about" class="hover:text-accent">About</a></li>
          <li><a href="/contact" class="hover:text-accent">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold mb-2">Legal</h4>
        <ul class="space-y-1 text-sm text-gray-400">
          <li><a href="/privacy-policy" class="hover:text-accent">Privacy Policy</a></li>
          <li><a href="/terms-of-service" class="hover:text-accent">Terms of Service</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold mb-2">Free Lawn Care Guide</h4>
        <p class="text-sm text-gray-400 mb-3">Get our essential seasonal lawn care checklist.</p>
        <EmailSignup source="footer" variant="compact" />
      </div>
    </div>
    <div class="border-t border-gray-700 mt-4 pt-4 text-center text-sm text-gray-500">
      &copy; {year} Turf Tech HQ. All rights reserved.
    </div>
  </div>
</footer>
