---
interface Props {
  heading?: string;
  description?: string;
  ctaText?: string;
  leadMagnet?: string;
  variant?: 'full' | 'compact' | 'inline';
}

const {
  heading = 'Get Your Free Lawn Care Guide',
  description = 'Join thousands of homeowners and landscapers. Get expert lawn care guides, seasonal tips, and garden solutions delivered to your inbox.',
  ctaText = 'Get the Free Guide',
  leadMagnet = 'Lawn Care Maintenance Guide',
  variant = 'full',
} = Astro.props;

const ckApiKey = import.meta.env.PUBLIC_CK_API_KEY || 'kit_c9479f8706aba6b9e2e8a9d2ef9407d0';
const uid = `email-signup-${variant}-${Math.random().toString(36).slice(2, 8)}`;
---

{variant === 'inline' ? (
  <form id={uid} class="email-signup-form flex gap-2">
    <input
      type="email"
      name="email"
      required
      placeholder="Enter your email"
      class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-light focus:border-transparent outline-none text-sm"
    />
    <button
      type="submit"
      class="bg-accent hover:bg-accent-light text-white font-semibold px-5 py-2 rounded-lg transition-colors duration-200 text-sm whitespace-nowrap"
    >
      {ctaText}
    </button>
  </form>
) : variant === 'compact' ? (
  <div class="email-signup bg-surface-dark text-white rounded-lg p-6">
    <h3 class="text-lg font-bold mb-2">{heading}</h3>
    <p class="text-sm text-gray-300 mb-4">{description}</p>
    <form id={uid} class="email-signup-form space-y-3">
      <input
        type="email"
        name="email"
        required
        placeholder="Enter your email address"
        class="w-full px-4 py-2 border border-gray-600 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent outline-none text-sm bg-gray-800 text-white placeholder-gray-400"
      />
      <button
        type="submit"
        class="w-full bg-accent hover:bg-accent-light text-white font-semibold px-5 py-2 rounded-lg transition-colors duration-200 text-sm"
      >
        {ctaText}
      </button>
    </form>
    <p class="text-xs text-gray-500 mt-3">
      No spam. Unsubscribe anytime. View our <a href="/privacy-policy" class="text-accent hover:text-accent-light underline">Privacy Policy</a>.
    </p>
  </div>
) : (
  <div class="email-signup bg-gradient-to-br from-primary to-primary-dark text-white rounded-xl p-8 md:p-12">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-3 font-heading">{heading}</h2>
      <p class="text-green-100 mb-6">{description}</p>
      <form id={uid} class="email-signup-form space-y-3">
        <input
          type="email"
          name="email"
          required
          placeholder="Enter your email address"
          class="w-full px-4 py-3 border border-green-400 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent outline-none text-gray-900 placeholder-gray-500"
        />
        <button
          type="submit"
          class="w-full bg-accent hover:bg-accent-light text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-200"
        >
          {ctaText}
        </button>
      </form>
      <p class="text-xs text-green-200 mt-4">
        No spam. Unsubscribe anytime. View our <a href="/privacy-policy" class="text-accent hover:text-accent-light underline">Privacy Policy</a>.
      </p>
    </div>
  </div>
)}

<script define:vars={{ uid, ckApiKey }}>
  (function () {
    var form = document.getElementById(uid);
    if (!form) return;
    var actualForm = form.tagName === 'FORM' ? form : form.querySelector('form');
    if (!actualForm) return;

    actualForm.addEventListener('submit', function (e) {
      e.preventDefault();
      var emailInput = actualForm.querySelector('input[name="email"]');
      var btn = actualForm.querySelector('button[type="submit"]');
      var email = emailInput ? emailInput.value.trim() : '';
      if (!email) return;

      if (!ckApiKey) {
        actualForm.innerHTML = '<p class="text-sm text-center py-4">Email capture is not yet configured. Please check back soon!</p>';
        return;
      }

      btn.disabled = true;
      var origText = btn.textContent;
      btn.textContent = 'Subscribing...';

      fetch('https://api.kit.com/v4/subscribers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Kit-Api-Key': ckApiKey },
        body: JSON.stringify({ email_address: email }),
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.subscriber) {
            actualForm.innerHTML =
              '<div class="text-center">' +
              '<p class="text-lg font-semibold mb-2">You\'re subscribed!</p>' +
              '<p class="text-sm">Thanks for signing up. We\'ll send you the best tips and guides.</p>' +
              '</div>';
          } else {
            btn.disabled = false;
            btn.textContent = origText;
            alert((data.errors && data.errors[0]) || 'Something went wrong. Please try again.');
          }
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = origText;
          alert('Sorry, there was an error. Please try again.');
        });
    });
  })();
</script>
