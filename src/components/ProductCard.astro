---
import type { Product } from '@/data/affiliate-products';
import { getGoUrl } from '@/data/affiliate-products';

interface Props {
  product: Product;
  showFeatures?: boolean;
}

const { product, showFeatures = true } = Astro.props;
const stars = Math.round(product.rating);
---

<div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col">
  <div class="mb-4">
    <span class="text-xs font-medium bg-primary/10 text-primary-dark px-2 py-1 rounded">
      {product.category}
    </span>
  </div>
  <h3 class="text-lg font-semibold mb-2 font-heading">{product.title}</h3>
  <p class="text-text-muted text-sm mb-4 flex-1">{product.description}</p>
  {showFeatures && (
    <ul class="text-sm text-text-muted mb-4 space-y-1">
      {product.features.map((f) => (
        <li class="flex items-start gap-2">
          <span class="text-primary mt-0.5">&#10003;</span>
          {f}
        </li>
      ))}
    </ul>
  )}
  <div class="flex items-center justify-between mt-auto">
    <div class="flex items-center gap-1">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          class={`w-4 h-4 ${i < stars ? 'text-accent' : 'text-gray-300'}`}
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
      <span class="text-sm text-text-muted ml-1">{product.rating}</span>
    </div>
    <span class="font-semibold text-text">{product.price}</span>
  </div>
  <a
    href={getGoUrl(product.slug)}
    target="_blank"
    rel="noopener noreferrer sponsored"
    class="mt-4 block text-center bg-primary hover:bg-primary-dark text-white font-semibold py-2 px-4 rounded-lg transition-colors duration-200"
  >
    View on Amazon
  </a>
</div>
