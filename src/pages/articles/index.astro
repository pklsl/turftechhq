---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
import { getCollection } from 'astro:content';

const DEFAULT_IMAGE = "https://images.pexels.com/photos/2132180/pexels-photo-2132180.jpeg?auto=compress&cs=tinysrgb&w=800";

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Landscaping Articles" description="Browse all Turf Tech HQ articles on lawn care, landscaping, garden maintenance, and outdoor living.">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-3 font-heading">Landscaping Articles</h1>
    <p class="text-text-muted text-lg mb-10">
      Expert guides and practical advice on lawn care, landscaping, garden tools, and outdoor maintenance.
    </p>

    <AdSlot slot="articles-top" format="horizontal" lazy={false} minHeight="90px" className="mb-10" />

    {articles.length === 0 ? (
      <p class="text-text-muted text-center py-16">Articles coming soon. Check back shortly.</p>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articles.map((article, i) => (
          <>
            {i === 3 && (
              <div class="col-span-full">
                <AdSlot slot="articles-listing-in-content" format="horizontal" lazy={true} minHeight="90px" />
              </div>
            )}
            <a
              href={`/articles/${article.id}`}
              class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 flex flex-col"
            >
              <div class="aspect-video overflow-hidden bg-gray-100">
                <img
                  src={article.data.image || DEFAULT_IMAGE}
                  alt={article.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading={i < 6 ? "eager" : "lazy"}
                />
              </div>
              <div class="p-6 flex flex-col flex-1">
                {article.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {article.data.tags.slice(0, 3).map((tag) => (
                      <span class="text-xs font-medium bg-primary/10 text-primary px-2.5 py-1 rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <h2 class="text-lg font-bold mb-2 group-hover:text-primary transition-colors leading-snug">
                  {article.data.title}
                </h2>
                <p class="text-text-muted text-sm line-clamp-2 flex-1 mb-4">
                  {article.data.description}
                </p>
                <time class="text-xs text-text-muted" datetime={article.data.pubDate.toISOString()}>
                  {article.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            </a>
          </>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
