---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CookieConsent from '@/components/CookieConsent.astro';

const ADSENSE_CLIENT = 'ca-pub-3974028728541243';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = 'Turf Tech HQ — Expert landscaping tips, lawn care guides, and garden solutions for homeowners and professionals.',
  canonical,
} = Astro.props;

const siteTitle = `${title} | Turf Tech HQ`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const adsenseEnabled = ADSENSE_CLIENT !== 'ca-pub-XXXXXXXXXXXXXXXX';
export { ADSENSE_CLIENT };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Turf Tech HQ" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />

    {adsenseEnabled && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
        crossorigin="anonymous"
      ></script>
    )}
    <meta name="impact-site-verification" value="7e1e0aff-5619-4bf6-ad84-7471dcb50416">
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-text font-body">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
